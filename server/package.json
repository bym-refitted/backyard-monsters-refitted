{
  "name": "backyard_monsters_refitted",
  "version": "1.4.4",
  "description": "The Backyard Monsters preservation project.",
  "author": "React1-X",
  "license": "GPL-3.0-only",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bun src/scripts/build-env.mjs",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "db:init": "bun run build && (bun --bun x mikro-orm schema:create -r || echo 'Schema already exists, continuing...') && bun --bun x mikro-orm migration:up",
    "db:seed": "bun src/seed.ts",
    "db:drop": "bun --bun x mikro-orm schema:drop --drop-db -r",
    "db:seed:mr2": "bun src/database/seeds/seed_maproom2.ts",
    "db:seed:mr3": "bun src/database/seeds/seed_maproom3.ts",
    "migration:up": "bun --bun x mikro-orm migration:up",
    "typecheck": "bunx tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@koa/router": "15.4.0",
    "@logtape/logtape": "2.0.5",
    "@logtape/pretty": "2.0.5",
    "@mikro-orm/core": "7.0.10",
    "@mikro-orm/decorators": "7.0.10",
    "@mikro-orm/postgresql": "7.0.10",
    "alea": "1.0.1",
    "bad-words": "4.0.0",
    "bcrypt": "6.0.0",
    "jsonwebtoken": "9.0.3",
    "koa": "3.2.0",
    "koa-bodyparser": "4.4.1",
    "koa-morgan": "1.0.1",
    "koa-static": "5.0.0",
    "koa2-ratelimit": "1.1.3",
    "nodemailer": "8.0.5",
    "simplex-noise": "4.0.3",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@mikro-orm/cli": "7.0.10",
    "@mikro-orm/migrations": "7.0.10",
    "@types/bcrypt": "6.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/koa": "3.0.2",
    "@types/koa-bodyparser": "5.0.2",
    "@types/koa-morgan": "1.0.9",
    "@types/koa-static": "4.0.4",
    "@types/koa2-ratelimit": "^0.9.7",
    "@types/koa__router": "12.0.5",
    "@types/nodemailer": "8.0.0",
    "bun-types": "1.3.12",
    "typescript": "6.0.2"
  },
  "mikro-orm": {
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  }
}
